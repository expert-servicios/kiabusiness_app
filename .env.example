# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Required in production: subscription checkout fails closed if these are missing.
# Planes mensuales
STRIPE_PLAN_MONTHLY_49=price_...
STRIPE_PLAN_MONTHLY_99=price_...
STRIPE_PLAN_MONTHLY_199=price_...
# Planes anuales (2 meses gratis = 10 mensualidades)
STRIPE_PLAN_ANNUAL_49=price_...
STRIPE_PLAN_ANNUAL_99=price_...
STRIPE_PLAN_ANNUAL_199=price_...

# Resend
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=

# Google reCAPTCHA v3
# Required in production: public form endpoints fail closed when the secret is missing.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_MIN_SCORE=0.5

# Holded — EXPERT global account (for EXPERT's own invoicing)
HOLDED_API_KEY=
HOLDED_SYNC_ENABLED=true
HOLDED_SYNC_DRY_RUN=false
HOLDED_SYNC_QUOTES=true
# IMPORTANT: Keep false to avoid duplicating invoices already received via Holded's
# native Stripe integration. Only set true if EXPERT is the invoice origin for that flow.
HOLDED_CREATE_INVOICES_FROM_STRIPE=false

# Architecture flags — new multi-client accounting model (see docs/holded-accounting-integration-audit.md)
# CRM and Projects are NOT used as EXPERT's operational source of truth.
HOLDED_SYNC_CRM_ENABLED=false
HOLDED_SYNC_PROJECTS_ENABLED=false
HOLDED_SYNC_ACCOUNTING_ENABLED=true
HOLDED_SYNC_FINANCE_ENABLED=true

# Legacy config for EXPERT global account
HOLDED_CRM_FUNNEL_ID=
HOLDED_CRM_DEFAULT_STAGE_ID=
HOLDED_PROJECT_DEFAULT_LIST_ID=
HOLDED_DEFAULT_QUOTE_DOC_TYPE=estimate
HOLDED_DEFAULT_TAX_ID=
HOLDED_DEFAULT_NUM_SERIE_ID=
HOLDED_DEFAULT_SALES_CHANNEL_ID=
HOLDED_DEFAULT_BANK_ID=

# Encryption key for client integration secrets (API keys stored in client_integrations)
# Generate with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# ── Holded MCP Bridge (server-to-server, claude.expertconsulting.es) ──────────
# Shared secret used by the Holded MCP server to authenticate calls to EXPERT.
# Must match EXPERT_APP_SHARED_SECRET on the MCP server (Vercel project holded-mcp).
# Generate with: openssl rand -hex 32
HOLDED_MCP_SHARED_SECRET=

# JWT secret for the __session bridge cookie (must match SESSION_SECRET on the MCP server).
# Required only when EXPERT_OAUTH_BRIDGE_ENABLED=1 on the MCP server.
# Generate with: openssl rand -hex 32
HOLDED_MCP_SESSION_SECRET=

# Comma-separated allowed hostnames for the MCP redirect (open-redirect guard).
HOLDED_MCP_BASE_URLS=claude.expertconsulting.es,claude.verifactu.business

# Cookie domain for the __session bridge cookie.
# Set to .expertconsulting.es once claude.expertconsulting.es DNS is active.
HOLDED_MCP_COOKIE_DOMAIN=
# Cal.com scheduling — set the event-type paths (username/event-slug) from cal.com/event-types
# The site constructs https://cal.com/{link} for embeds and popups.
NEXT_PUBLIC_CAL_REUNION_LINK=your-username/reunion
NEXT_PUBLIC_CAL_DEMO_LINK=your-username/demo
NEXT_PUBLIC_CAL_ONBOARDING_LINK=your-username/onboarding
NEXT_PUBLIC_CAL_FORMACION_LINK=your-username/formacion
# Cal.com webhook secret — copy from cal.com/settings/developer/webhooks after adding the endpoint
# Webhook URL: https://expertconsulting.es/api/webhooks/cal
CAL_WEBHOOK_SECRET=
# Cal.com API key — from cal.com/settings/developer/api-keys (optional, for server-side booking queries)
CAL_API_KEY=

# Holded public URLs (used in ReadinessModal and Kia engine)
NEXT_PUBLIC_HOLDED_TRIAL_URL=https://www.holded.com/es
NEXT_PUBLIC_HOLDED_API_DOCS_URL=https://developers.holded.com
NEXT_PUBLIC_HOLDED_ACADEMY_URL=https://www.holded.com/es/academia
NEXT_PUBLIC_HOLDED_MCP_BASE_URL=https://claude.expertconsulting.es

# Meta WhatsApp Business Cloud API
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# AI — Claude (Anthropic) primary, OpenAI fallback
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini
AI_PROVIDER=anthropic
KIA_STRUCTURED_AI_ENABLED=true
KIA_STRUCTURED_AI_ADMIN_ENABLED=true
KIA_STRUCTURED_AI_WABA_ENABLED=true
KIA_AI_DECISION_LOGS_ENABLED=true
KIA_AI_PROVIDER_ROUTER_ENABLED=true
KIA_AI_EVAL_MODE=false
KIA_AI_TOOLS_ENABLED=false
KIA_COPILOT_TOOLS_ENABLED=true
KIA_AI_DOCUMENT_CLASSIFICATION_ENABLED=false
KIA_AI_ACCOUNTING_SUMMARY_ENABLED=false
KIA_HEALTH_ENABLED=true
KIA_HEALTH_CANARY_ENABLED=true
KIA_HEALTH_NIGHTLY_ENABLED=false
KIA_HEALTH_ALERTS_ENABLED=true
KIA_HEALTH_AUTO_DISABLE_STRUCTURED_AI=false
KIA_HEALTH_MAX_LATENCY_MS=10000
KIA_HEALTH_MAX_INVALID_JSON_RATE=0.05
KIA_HEALTH_MAX_NEEDS_REVIEW_RATE=0.15
OFFICIAL_SEARCH_ENABLED=true
OFFICIAL_SEARCH_MODEL=gpt-4.1-mini

# Company data enrichment (optional)
# OpenCorporates: https://opencorporates.com/info/api — required for OpenCorporates source
OPENCORPORATES_API_KEY=
# Registradores de España: pending official API — contact informatica@registradores.org
REGISTRADORES_API_KEY=

# General
NEXT_PUBLIC_APP_URL=https://expertconsulting.es
ADMIN_EMAILS=soy@expertconsulting.es,expertestudiospro@gmail.com,info@expertconsulting.es
# Required for Vercel Cron endpoints. Production cron routes fail closed when missing.
CRON_SECRET=

# Required for internal server-to-server calls. Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# Signed nonce for external OAuth callbacks (Gmail, Google Calendar, MS365).
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# ── Google OAuth (for Gmail + Google Calendar user integrations) ────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI: {APP_URL}/api/auth/google-calendar/callback and /google-gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Drive (Service Account — for client document storage) ────────────
# Create a Service Account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant it "Editor" access to the shared Drive folder below.
GOOGLE_DRIVE_SA_EMAIL=
# Private key from the service account JSON — include full PEM with newlines as \n
GOOGLE_DRIVE_SA_PRIVATE_KEY=
# Google Drive folder ID where client subfolders are created
GOOGLE_DRIVE_CLIENTS_FOLDER_ID=

# ── Google Gmail (Service Account — for sending via client Gmail aliases) ───
# Requires domain-wide delegation in Google Workspace Admin.
GOOGLE_GMAIL_SA_EMAIL=
GOOGLE_GMAIL_SA_PRIVATE_KEY=

# ── Microsoft 365 (for MS365 calendar/email integrations) ───────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Add redirect URI: {APP_URL}/api/auth/ms365/callback
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=

# ── Web Push Notifications (VAPID) ──────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be a mailto: or https: URL identifying the server operator
VAPID_SUBJECT=mailto:soy@expertconsulting.es

# ── CKAN Open Data Sources (optional) ────────────────────────────────────────
# Enable to fetch data from a custom CKAN instance (e.g., datos.gob.es)
CKAN_SOURCES_ENABLED=false
CKAN_CUSTOM_BASE_URL=https://datos.gob.es
CKAN_CUSTOM_SOURCE_NAME=datos.gob.es

# ── Kia Auditor & Health feature flags ──────────────────────────────────────
# Enable LLM-based Kia response quality evaluation (requires ANTHROPIC_API_KEY)
KIA_AUDITOR_LLM_ENABLED=false
# Show a warning in health checks when Kia tools are enabled (set true in prod)
KIA_HEALTH_ALLOW_TOOLS_ENABLED_WARNING=false
