# ============================================================
# Holded MCP Server — EXPERT / Claude
# Copia este fichero a .env y rellena los valores reales.
# Nunca commitees .env.
# ============================================================

# Servidor
PORT=3000
NODE_ENV=production
BASE_URL=https://claude.expertconsulting.es
CORS_ALLOWED_ORIGINS=https://claude.ai,https://app.claude.ai
DATABASE_URL=postgresql://postgres:password@localhost:5432/expert_holded_mcp?schema=public
ALLOW_STATELESS_OAUTH_IN_PRODUCTION=0

# OAuth 2.0
# Genera secretos seguros: openssl rand -hex 32
OAUTH_JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_64_CHARS
OAUTH_DATA_ENCRYPTION_SECRET=CAMBIA_ESTO_POR_OTRO_SECRETO_SEGURO_DE_64_CHARS
OAUTH_AUTH_CODE_TTL_SECONDS=600
OAUTH_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# OAuth Client para Claude
OAUTH_CLIENT_ID=claude-holded-connector
OAUTH_CLIENT_SECRET=CAMBIA_ESTO_POR_OTRO_SECRETO

# Holded API
HOLDED_API_BASE=https://api.holded.com

# Integracion EXPERT
EXPERT_APP_URL=https://expertconsulting.es
EXPERT_PUBLIC_URL=https://expertconsulting.es
# Fase actual: standalone. Activar solo cuando existan los endpoints EXPERT:
# /auth/holded-claude
# /api/integrations/holded/upsert-from-key
# /api/integrations/holded/connection-status
# /api/integrations/holded/connector-event
EXPERT_OAUTH_BRIDGE_ENABLED=0
EXPERT_CENTRAL_REGISTRY_ENABLED=0
EXPERT_APP_SHARED_SECRET=
SESSION_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
